# QuoteMe Frontend - environment variables
# Copy to .env.local for local development. Never commit .env.local.

# ---- Runtime vars (exposed to browser, prefix VITE_) ----

# Google Maps Places autocomplete (set in Vercel dashboard for deployed envs)
VITE_GOOGLE_MAPS_API_KEY=

# Sentry error monitoring
# Set in Vercel dashboard for each deployment environment.
# Leave blank locally to disable Sentry (beforeSend no-ops when unset).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# Populated automatically in CI/Vercel via $VERCEL_GIT_COMMIT_SHA or similar.
VITE_RELEASE_SHA=

# ---- Build-time secrets (NOT VITE_* — never exposed to browser) ----
# Set these in the Vercel dashboard under Environment Variables (not prefixed VITE_).
# They are used only during `vite build` to upload source maps to Sentry.
#
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
