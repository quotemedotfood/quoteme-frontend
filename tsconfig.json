{
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": false,
    "isolatedModules": true,
    "noEmitOnError": false,
    "types": ["node", "vite/client", "google.maps"]
  },
  "include": ["src"]
}
